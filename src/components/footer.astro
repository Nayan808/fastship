---
import { Icon } from "astro-icon/components";
---

<footer class="mt-20 border-t border-gray-200">

  
  <!-- Main Footer -->
  <div class="py-12 bg-white">
    <div class="max-w-6xl mx-auto px-8">
      <div class="grid md:grid-cols-4 gap-8">
        <!-- Company Info -->
        <div class="md:col-span-2">
          <div class="flex items-center gap-2 mb-4">
            <Icon class="w-6 h-6 text-black" name="bx:home" />
            <span class="text-lg font-bold text-gray-900">FastShip</span>
          </div>
          <p class="text-black mb-6 max-w-md">
            We don't just ship code, We launch Rocket. Transform your business with AI-powered development and elite engineering teams.
          </p>
          <div class="flex items-center gap-4">
            <a href="mailto:contact@fastship.work" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
              <Icon class="w-5 h-5 text-black" name="bx:envelope" />
            </a>
            <a href="https://linkedin.com/company/fastship-work" target="_blank" rel="noopener" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
              <Icon class="w-5 h-5 text-black" name="bx:bxl-linkedin" />
            </a>
          </div>
        </div>
        
        <!-- Quick Links -->
        <div>
          <h4 class="font-semibold text-gray-900 mb-4">Quick Links</h4>
          <ul class="space-y-2">
            <li><a href="/about" class="text-gray-600 hover:text-black transition-colors">About</a></li>
            <li><a href="/#services" class="text-gray-600 hover:text-black transition-colors">Services</a></li>
            <li><a href="/careers" class="text-gray-600 hover:text-black transition-colors">Careers</a></li>

          </ul>
        </div>
        
        <!-- Resources -->
        <div>
          <h4 class="font-semibold text-gray-900 mb-4">Resources</h4>
          <ul class="space-y-2">
            <li><a href="/privacy-policy" class="text-gray-600 hover:text-black transition-colors">Privacy Policy</a></li>
            <li><a href="/terms-of-service" class="text-gray-600 hover:text-black transition-colors">Terms of Service</a></li>
          </ul>
        </div>
      </div>
      
      <!-- Bottom Bar -->
      <div class="border-t border-gray-200 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center">
        <p class="text-black text-sm">
          © 2025 FastShip. All rights reserved.
        </p>
        <div class="flex flex-col items-center md:items-end mt-2 md:mt-0">
          <!-- Product Hunt Upvote Badge -->
          <a href="https://www.producthunt.com/products/fastship?embed=true&utm_source=badge-featured&utm_medium=badge&utm_source=badge-fastship" target="_blank" class="mb-2">
            <img src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1010555&theme=dark&t=1756537805378" alt="FastShip - We don't just ship code, We launch Rocket 🚀 | Product Hunt" style="width: 250px; height: 54px;" width="250" height="54" />
          </a>
          <p class="text-black text-sm">
            We don't just ship code, We launch Rocket 🚀
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
