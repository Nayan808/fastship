---
import { Icon } from "astro-icon/components";
---

<div class="mt-20 md:mt-32" id="reviews">
  <div class="flex items-center justify-between mb-16">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight text-black">
      What our clients say
    </h2>
    <div class="flex gap-3">
      <button id="prevBtn" class="w-12 h-12 bg-gray-200 rounded-full flex items-center justify-center hover:bg-gray-300 transition-colors">
        <Icon class="w-6 h-6 text-black" name="bx:chevron-left" />
      </button>
      <button id="nextBtn" class="w-12 h-12 bg-gray-200 rounded-full flex items-center justify-center hover:bg-gray-300 transition-colors">
        <Icon class="w-6 h-6 text-black" name="bx:chevron-right" />
      </button>
    </div>
  </div>

  <div class="max-w-6xl mx-auto relative overflow-hidden">
    <div id="testimonialContainer" class="flex transition-transform duration-300 ease-in-out">
      <!-- Testimonial 1 - Emily Rodriguez, PinPoint -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "Our team's productivity soared with this messaging tool. Its simplicity fosters quick decision-making and seamless collaboration, essential for our fast-paced product development."
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                ER
              </div>
              <div>
                <h4 class="font-semibold text-black">Emily Rodriguez</h4>
                <p class="text-sm text-black">Emily Rodriguez, PinPoint</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">PinPoint</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 2 - David Patel, Hues -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "With this tool, our team's workflow has become more efficient and organized. We spend less time navigating complex interfaces and more time focusing on what matters: delivering quality products to our customers."
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                DP
              </div>
              <div>
                <h4 class="font-semibold text-black">David Patel</h4>
                <p class="text-sm text-black">David Patel, Hues</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">hues</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 3 - Rachel Kim, Greenish -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "We've seen remarkable results since integrating AI solutions from this company into our workflows. Their computer vision technology has enabled us to automate tasks and extract valuable insights from visual data."
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                RK
              </div>
              <div>
                <h4 class="font-semibold text-black">Rachel Kim</h4>
                <p class="text-sm text-black">Rachel Kim, Greenish</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">Greenish</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 4 - David P, PinPoint -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "We've seen seamless integration into our technology, making tasks and visual data processing incredibly efficient. The results have exceeded our expectations."
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                DP
              </div>
              <div>
                <h4 class="font-semibold text-black">David P</h4>
                <p class="text-sm text-black">David Pa, PinPoint</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">PinPoint</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  let currentIndex = 0;
  const totalTestimonials = 4;
  const container = document.getElementById('testimonialContainer');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');

  function updateNavigation() {
    // Update button states
    prevBtn.classList.toggle('bg-gray-300', currentIndex === 0);
    prevBtn.classList.toggle('bg-gray-200', currentIndex !== 0);
    nextBtn.classList.toggle('bg-gray-300', currentIndex === totalTestimonials - 1);
    nextBtn.classList.toggle('bg-gray-200', currentIndex !== totalTestimonials - 1);
  }

  function showTestimonial(index) {
    currentIndex = index;
    const translateX = -index * 100;
    container.style.transform = `translateX(${translateX}%)`;
    updateNavigation();
  }

  prevBtn.addEventListener('click', () => {
    if (currentIndex > 0) {
      showTestimonial(currentIndex - 1);
    }
  });

  nextBtn.addEventListener('click', () => {
    if (currentIndex < totalTestimonials - 1) {
      showTestimonial(currentIndex + 1);
    }
  });

  // Initialize
  updateNavigation();
</script>

<style>
  .testimonial-card {
    transition: all 0.3s ease;
  }
  
  #testimonialContainer {
    will-change: transform;
  }
</style>
