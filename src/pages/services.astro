---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import SectionHead from "@/components/sectionhead.astro";

// Enhanced SEO for services page to outrank competitors
const seoTitle = "IT Services & Software Development Solutions | FastShip - Premier Technology Company";
const seoDescription = "FastShip offers comprehensive IT services including custom software development, AI-powered solutions, digital transformation, web development, mobile apps, cloud solutions, and DevOps. Get 10x faster results with our elite engineering teams.";
const seoKeywords = "IT services, software development services, custom software development, AI development services, digital transformation services, web development services, mobile app development, cloud computing services, DevOps services, software consulting, enterprise software development, startup software development, AI-powered development, machine learning services, cloud solutions, web application development, mobile application development, software architecture services, microservices development, API development services, database design services, UI/UX design services, frontend development services, backend development services, full-stack development services, React development, Node.js development, Python development, Java development, .NET development, AWS services, Azure services, Google Cloud services, Kubernetes consulting, Docker consulting, CI/CD services, continuous integration, continuous deployment, agile development services, scrum methodology, kanban methodology, project management services, technical consulting services, code review services, testing services, quality assurance services, performance optimization services, security auditing services, compliance services, GDPR compliance, HIPAA compliance, SOC 2 compliance, ISO 27001 compliance, FastShip, fastship.co competitor, premier IT company";

// Structured data for services page
const servicesStructuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "FastShip IT Services",
  "description": "Comprehensive IT services and software development solutions",
  "url": "https://fastship.com/services",
  "numberOfItems": 8,
  "itemListElement": [
    {
      "@type": "Service",
      "position": 1,
      "name": "Custom Software Development",
      "description": "Tailored software solutions for your business needs",
      "url": "https://fastship.com/services#custom-software"
    },
    {
      "@type": "Service",
      "position": 2,
      "name": "AI-Powered Development",
      "description": "Intelligent solutions using artificial intelligence and machine learning",
      "url": "https://fastship.com/services#ai-development"
    },
    {
      "@type": "Service",
      "position": 3,
      "name": "Digital Transformation",
      "description": "Complete digital transformation of your business processes",
      "url": "https://fastship.com/services#digital-transformation"
    },
    {
      "@type": "Service",
      "position": 4,
      "name": "Web Development",
      "description": "Modern web applications and websites",
      "url": "https://fastship.com/services#web-development"
    },
    {
      "@type": "Service",
      "position": 5,
      "name": "Mobile App Development",
      "description": "Native and cross-platform mobile applications",
      "url": "https://fastship.com/services#mobile-development"
    },
    {
      "@type": "Service",
      "position": 6,
      "name": "Cloud Solutions",
      "description": "AWS, Azure, and Google Cloud services",
      "url": "https://fastship.com/services#cloud-solutions"
    },
    {
      "@type": "Service",
      "position": 7,
      "name": "DevOps Services",
      "description": "Continuous integration and deployment solutions",
      "url": "https://fastship.com/services#devops"
    },
    {
      "@type": "Service",
      "position": 8,
      "name": "Software Consulting",
      "description": "Expert technical consulting and strategy",
      "url": "https://fastship.com/services#consulting"
    }
  ]
};

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://fastship.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": "https://fastship.com/services"
    }
  ]
};
---

<Layout 
  title="IT Services & Software Development Solutions"
  description={seoDescription}
  keywords={seoKeywords}
  image="/logo.jpeg"
  structuredData={[servicesStructuredData, breadcrumbData]}
>
  <Container>
    <div class="mx-auto max-w-4xl mt-16">
      <SectionHead
        title="Our Comprehensive IT Services"
        description="Delivering cutting-edge technology solutions that drive business growth and innovation"
      />
      
      <div class="grid gap-8 mt-16">
        <!-- Custom Software Development -->
        <div id="custom-software" class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Custom Software Development</h2>
          <p class="text-lg text-gray-600 mb-6">
            We build tailored software solutions that perfectly align with your business requirements. 
            From enterprise applications to startup MVPs, our custom software development services 
            deliver scalable, maintainable, and high-performance solutions.
          </p>
          <ul class="space-y-2 text-gray-700">
            <li>• Enterprise Software Solutions</li>
            <li>• Startup MVP Development</li>
            <li>• Legacy System Modernization</li>
            <li>• Scalable Architecture Design</li>
          </ul>
        </div>

        <!-- AI-Powered Development -->
        <div id="ai-development" class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">AI-Powered Development</h2>
          <p class="text-lg text-gray-600 mb-6">
            Harness the power of artificial intelligence and machine learning to create intelligent 
            applications that learn, adapt, and improve over time. Our AI solutions drive innovation 
            and provide competitive advantages.
          </p>
          <ul class="space-y-2 text-gray-700">
            <li>• Machine Learning Applications</li>
            <li>• Natural Language Processing</li>
            <li>• Computer Vision Solutions</li>
            <li>• Predictive Analytics</li>
          </ul>
        </div>

        <!-- Digital Transformation -->
        <div id="digital-transformation" class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Digital Transformation</h2>
          <p class="text-lg text-gray-600 mb-6">
            Transform your business with cutting-edge digital solutions. We help organizations 
            modernize their operations, improve customer experiences, and stay ahead of the 
            competition through strategic digital initiatives.
          </p>
          <ul class="space-y-2 text-gray-700">
            <li>• Process Automation</li>
            <li>• Customer Experience Optimization</li>
            <li>• Data-Driven Decision Making</li>
            <li>• Technology Stack Modernization</li>
          </ul>
        </div>

        <!-- Web Development -->
        <div id="web-development" class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Web Development</h2>
          <p class="text-lg text-gray-600 mb-6">
            Create stunning, responsive web applications that engage users and drive business results. 
            Our web development expertise covers everything from simple websites to complex 
            web applications with modern frameworks and technologies.
          </p>
          <ul class="space-y-2 text-gray-700">
            <li>• Responsive Web Design</li>
            <li>• Progressive Web Apps (PWA)</li>
            <li>• E-commerce Solutions</li>
            <li>• Content Management Systems</li>
          </ul>
        </div>

        <!-- Mobile App Development -->
        <div id="mobile-development" class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Mobile App Development</h2>
          <p class="text-lg text-gray-600 mb-6">
            Build powerful mobile applications that users love. We develop native and cross-platform 
            mobile apps for iOS and Android, ensuring optimal performance, user experience, 
            and market success.
          </p>
          <ul class="space-y-2 text-gray-700">
            <li>• Native iOS Development</li>
            <li>• Native Android Development</li>
            <li>• Cross-Platform Solutions</li>
            <li>• App Store Optimization</li>
          </ul>
        </div>

        <!-- Cloud Solutions -->
        <div id="cloud-solutions" class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Cloud Solutions</h2>
          <p class="text-lg text-gray-600 mb-6">
            Leverage the power of cloud computing to scale your business efficiently. Our cloud 
            solutions include migration, optimization, and management across major cloud platforms 
            like AWS, Azure, and Google Cloud.
          </p>
          <ul class="space-y-2 text-gray-700">
            <li>• Cloud Migration Services</li>
            <li>• Multi-Cloud Strategy</li>
            <li>• Serverless Architecture</li>
            <li>• Cloud Security & Compliance</li>
          </ul>
        </div>

        <!-- DevOps Services -->
        <div id="devops" class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">DevOps Services</h2>
          <p class="text-lg text-gray-600 mb-6">
            Streamline your development and operations with modern DevOps practices. We implement 
            CI/CD pipelines, infrastructure as code, and automation solutions that accelerate 
            delivery and improve reliability.
          </p>
          <ul class="space-y-2 text-gray-700">
            <li>• CI/CD Pipeline Implementation</li>
            <li>• Infrastructure as Code</li>
            <li>• Container Orchestration</li>
            <li>• Monitoring & Logging</li>
          </ul>
        </div>

        <!-- Software Consulting -->
        <div id="consulting" class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Software Consulting</h2>
          <p class="text-lg text-gray-600 mb-6">
            Get expert guidance on your technology decisions and strategy. Our consulting services 
            help you make informed choices about architecture, technology selection, and 
            implementation approaches.
          </p>
          <ul class="space-y-2 text-gray-700">
            <li>• Technology Strategy</li>
            <li>• Architecture Review</li>
            <li>• Code Quality Assessment</li>
            <li>• Performance Optimization</li>
          </ul>
        </div>
      </div>

      <!-- Call to Action -->
      <div class="text-center mt-16 bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg p-8 text-white">
        <h3 class="text-2xl font-bold mb-4">Ready to Transform Your Business?</h3>
        <p class="text-lg mb-6">
          Let's discuss how our IT services can help you achieve your goals and stay ahead of the competition.
        </p>
        <a href="/contact" class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
          Get Started Today
        </a>
      </div>
    </div>
  </Container>
</Layout>
