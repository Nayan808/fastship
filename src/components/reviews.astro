---
import { Icon } from "astro-icon/components";
---

<div class="mt-20 md:mt-32" id="reviews">
  <div class="flex items-center justify-between mb-16">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight text-black">
      What our clients say
    </h2>
    <div class="flex gap-3">
      <button id="prevBtn" class="w-12 h-12 bg-gray-200 rounded-full flex items-center justify-center hover:bg-gray-300 transition-colors">
        <Icon class="w-6 h-6 text-black" name="bx:chevron-left" />
      </button>
      <button id="nextBtn" class="w-12 h-12 bg-gray-200 rounded-full flex items-center justify-center hover:bg-gray-300 transition-colors">
        <Icon class="w-6 h-6 text-black" name="bx:chevron-right" />
      </button>
    </div>
  </div>

  <div class="max-w-6xl mx-auto relative overflow-hidden">
    <div id="testimonialContainer" class="flex transition-transform duration-300 ease-in-out">
      <!-- Testimonial 1 - Priya Sharma, TechFlow -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "FastShip transformed our development process completely. We went from 6-month project cycles to launching MVPs in just 3 weeks. Their AI-powered approach is game-changing for startups like ours."
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                PS
              </div>
              <div>
                <h4 class="font-semibold text-black">Priya Sharma</h4>
                <p class="text-sm text-black">CTO & Co-founder, TechFlow</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">TechFlow</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 2 - Marcus Chen, DataVault -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "The team at FastShip built our entire data analytics platform in record time. Their expertise in AI and cloud architecture helped us scale from 0 to 10,000 users in just 4 months. Absolutely incredible work!"
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                MC
              </div>
              <div>
                <h4 class="font-semibold text-black">Marcus Chen</h4>
                <p class="text-sm text-black">Founder & CEO, DataVault</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">DataVault</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 3 - Aarav Patel, GreenEats -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "FastShip delivered our food delivery app faster than we thought possible. Their full-stack development skills and attention to detail made all the difference. We're now processing 500+ orders daily!"
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                AP
              </div>
              <div>
                <h4 class="font-semibold text-black">Aarav Patel</h4>
                <p class="text-sm text-black">Co-founder, GreenEats</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">GreenEats</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 4 - Sarah Johnson, FinTechPro -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "Working with FastShip was a breath of fresh air. They understood our fintech requirements perfectly and built a secure, scalable platform that exceeded our expectations. Highly recommend!"
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                SJ
              </div>
              <div>
                <h4 class="font-semibold text-black">Sarah Johnson</h4>
                <p class="text-sm text-black">Product Manager, FinTechPro</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">FinTechPro</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 5 - Rajesh Kumar, EduTech -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "FastShip helped us build an AI-powered learning platform that's now used by 50,000+ students. Their technical expertise and understanding of edtech made this project a huge success."
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                RK
              </div>
              <div>
                <h4 class="font-semibold text-black">Rajesh Kumar</h4>
                <p class="text-sm text-black">Founder, EduTech</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">EduTech</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 6 - Emma Rodriguez, HealthSync -->
      <div class="testimonial-card w-full flex-shrink-0 px-4">
        <div class="bg-white p-8 rounded-xl shadow-lg border border-gray-100 max-w-4xl mx-auto">
          <p class="text-black mb-6 italic text-lg leading-relaxed">
            "FastShip delivered our healthcare management system on time and under budget. Their expertise in building secure, HIPAA-compliant applications was exactly what we needed. Outstanding team!"
          </p>
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-black font-semibold mr-4">
                ER
              </div>
              <div>
                <h4 class="font-semibold text-black">Emma Rodriguez</h4>
                <p class="text-sm text-black">CTO, HealthSync</p>
              </div>
            </div>
            <div class="text-sm font-medium text-gray-500">HealthSync</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  let currentIndex = 0;
  const totalTestimonials = 6;
  const container = document.getElementById('testimonialContainer');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');

  function updateNavigation() {
    // Update button states
    prevBtn.classList.toggle('bg-gray-300', currentIndex === 0);
    prevBtn.classList.toggle('bg-gray-200', currentIndex !== 0);
    nextBtn.classList.toggle('bg-gray-300', currentIndex === totalTestimonials - 1);
    nextBtn.classList.toggle('bg-gray-200', currentIndex !== totalTestimonials - 1);
  }

  function showTestimonial(index) {
    currentIndex = index;
    const translateX = -index * 100;
    container.style.transform = `translateX(${translateX}%)`;
    updateNavigation();
  }

  prevBtn.addEventListener('click', () => {
    if (currentIndex > 0) {
      showTestimonial(currentIndex - 1);
    }
  });

  nextBtn.addEventListener('click', () => {
    if (currentIndex < totalTestimonials - 1) {
      showTestimonial(currentIndex + 1);
    }
  });

  // Initialize
  updateNavigation();
</script>

<style>
  .testimonial-card {
    transition: all 0.3s ease;
  }
  
  #testimonialContainer {
    will-change: transform;
  }
</style>
