---
import { Icon } from "astro-icon/components";
---

<div class="mt-20 md:mt-32" id="for-roles">
  <div class="text-center mb-16">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
      Built for Every Leader
    </h2>
    <p class="text-xl mt-6 text-slate-600 max-w-4xl mx-auto">
      Transform complex workflows into secure, enterprise-grade software using AI agents and elite engineers, 
      executed fast with an outcome-first delivery model.
    </p>
  </div>

  <div class="max-w-4xl mx-auto space-y-4">
    <!-- For Founders -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-white p-6 cursor-pointer hover:bg-gray-50 transition-colors" onclick="toggleAccordion('founders')">
        <div class="flex items-center justify-between">
          <h3 class="text-xl font-semibold italic">For Founders</h3>
          <Icon id="founders-icon" class="text-gray-400 w-6 h-6 transition-transform" name="bx:minus" />
        </div>
        <div id="founders-content" class="mt-4 bg-blue-50 p-6 rounded-lg">
          <h4 class="text-blue-600 font-semibold text-lg mb-3">
            Your vision deserves more than just code.
          </h4>
          <ul class="space-y-2 text-slate-700">
            <li>• Prototypes become production-ready solutions</li>
            <li>• We scale with your growth, not against it</li>
            <li>• Ship before your competitors even start planning</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- For Revenue Leaders -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-white p-6 cursor-pointer hover:bg-gray-50 transition-colors" onclick="toggleAccordion('revenue')">
        <div class="flex items-center justify-between">
          <h3 class="text-xl font-semibold italic">For Revenue Leaders</h3>
          <Icon id="revenue-icon" class="text-gray-400 w-6 h-6 transition-transform" name="bx:plus" />
        </div>
        <div id="revenue-content" class="mt-4 bg-green-50 p-6 rounded-lg hidden">
          <h4 class="text-green-600 font-semibold text-lg mb-3">
            Drive revenue with technology that converts.
          </h4>
          <ul class="space-y-2 text-slate-700">
            <li>• Customer-facing apps that boost conversion rates</li>
            <li>• Analytics dashboards that reveal revenue opportunities</li>
            <li>• Integration systems that streamline sales processes</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- For Engineering Leaders -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-white p-6 cursor-pointer hover:bg-gray-50 transition-colors" onclick="toggleAccordion('engineering')">
        <div class="flex items-center justify-between">
          <h3 class="text-xl font-semibold italic">For Engineering Leaders</h3>
          <Icon id="engineering-icon" class="text-gray-400 w-6 h-6 transition-transform" name="bx:plus" />
        </div>
        <div id="engineering-content" class="mt-4 bg-purple-50 p-6 rounded-lg hidden">
          <h4 class="text-purple-600 font-semibold text-lg mb-3">
            Scale your engineering without the overhead.
          </h4>
          <ul class="space-y-2 text-slate-700">
            <li>• AI-powered development that accelerates your team</li>
            <li>• Enterprise-grade architecture from day one</li>
            <li>• DevOps automation that reduces deployment friction</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- For Customer Leaders -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-white p-6 cursor-pointer hover:bg-gray-50 transition-colors" onclick="toggleAccordion('customer')">
        <div class="flex items-center justify-between">
          <h3 class="text-xl font-semibold italic">For Customer Leaders</h3>
          <Icon id="customer-icon" class="text-gray-400 w-6 h-6 transition-transform" name="bx:plus" />
        </div>
        <div id="customer-content" class="mt-4 bg-orange-50 p-6 rounded-lg hidden">
          <h4 class="text-orange-600 font-semibold text-lg mb-3">
            Deliver experiences that customers love.
          </h4>
          <ul class="space-y-2 text-slate-700">
            <li>• User interfaces that delight and engage</li>
            <li>• Customer journey optimization through data</li>
            <li>• Support systems that resolve issues instantly</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleAccordion(section) {
    const content = document.getElementById(section + '-content');
    const icon = document.getElementById(section + '-icon');
    
    if (content.classList.contains('hidden')) {
      // Close all other sections
      document.querySelectorAll('[id$="-content"]').forEach(el => {
        el.classList.add('hidden');
      });
      document.querySelectorAll('[id$="-icon"]').forEach(el => {
        el.setAttribute('name', 'bx:plus');
      });
      
      // Open this section
      content.classList.remove('hidden');
      icon.setAttribute('name', 'bx:minus');
    } else {
      // Close this section
      content.classList.add('hidden');
      icon.setAttribute('name', 'bx:plus');
    }
  }
</script>
