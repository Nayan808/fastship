---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import SectionHead from "@/components/sectionhead.astro";
import ContactForm from "@/components/contactform.astro";

// Enhanced SEO for contact page to outrank competitors
const seoTitle = "Contact FastShip - Get IT Services & Software Development Quote | Premier Technology Company";
const seoDescription = "Contact FastShip for expert IT services, custom software development, AI solutions, and digital transformation. Get a free consultation and quote from our technology experts. Start your project today.";
const seoKeywords = "contact FastShip, FastShip contact, IT services contact, software development contact, get quote, free consultation, technology consultation, AI development contact, custom software quote, digital transformation contact, web development contact, mobile app development contact, cloud solutions contact, DevOps services contact, software consulting contact, project inquiry, technology partnership, FastShip, fastship.co competitor, premier IT company contact";

// Structured data for contact page
const contactStructuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact FastShip",
  "description": "Get in touch with FastShip for IT services and software development solutions",
  "url": "https://fastship.work/contact",
  "mainEntity": {
    "@type": "Organization",
    "name": "FastShip",
    "url": "https://fastship.work",
    "contactPoint": [
      {
        "@type": "ContactPoint",
        "telephone": "+1-555-0123",
        "contactType": "customer service",
        "availableLanguage": "English",
        "hoursAvailable": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday"
          ],
          "opens": "09:00",
          "closes": "18:00"
        }
      },
      {
        "@type": "ContactPoint",
        "contactType": "technical support",
        "availableLanguage": "English",
        "hoursAvailable": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday"
          ],
          "opens": "00:00",
          "closes": "23:59"
        }
      }
    ],
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "US"
    }
  }
};

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://fastship.work"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Contact",
      "item": "https://fastship.work/contact"
    }
  ]
};
---

<Layout 
  title="Contact FastShip - Get IT Services Quote"
  description={seoDescription}
  keywords={seoKeywords}
  image="/logo.jpeg"
  structuredData={[contactStructuredData, breadcrumbData]}
>
  <Container>
    <div class="mx-auto max-w-6xl mt-16">
      <SectionHead
        title="Contact FastShip - Get in Touch Today"
        description="Ready to transform your business with cutting-edge technology solutions? Let's discuss your project and how we can help you achieve 10x faster results. Get a free consultation and project quote."
      />
      
      <div class="grid lg:grid-cols-2 gap-12 mt-16">
        <!-- Contact Information -->
        <div class="space-y-8">
          <div class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">Let's Start Your Project</h3>
            <p class="text-gray-600 mb-6 leading-relaxed">
              Whether you need custom software development, AI-powered solutions, or digital transformation, 
              our team of experts is ready to help you succeed. Get in touch for a free consultation 
              and project quote.
            </p>
            
            <div class="space-y-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Email Us</h4>
                  <p class="text-gray-600">contact@fastship.work</p>
                </div>
              </div>
              
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Call Us</h4>
                  <p class="text-gray-600">+1 (555) 012-3456</p>
                </div>
              </div>
              
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Business Hours</h4>
                  <p class="text-gray-600">Mon-Fri: 9:00 AM - 6:00 PM EST</p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Why Choose FastShip -->
          <div class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">Why Choose FastShip?</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-gray-600 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <p class="text-gray-700">Free initial consultation and project assessment</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-gray-600 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <p class="text-gray-700">Detailed project proposal with transparent pricing</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-gray-600 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <p class="text-gray-700">Dedicated project manager and development team</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-gray-600 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <p class="text-gray-700">Ongoing support and maintenance after launch</p>
              </div>
            </div>
          </div>
          
          <!-- Services Overview -->
          <div class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">Our Services Overview</h3>
            <div class="grid grid-cols-2 gap-4">
              <div class="text-center p-4 bg-gray-50 rounded-lg">
                <h4 class="font-semibold text-gray-900">Custom Software</h4>
                <p class="text-sm text-gray-600">Tailored solutions</p>
              </div>
              <div class="text-center p-4 bg-gray-50 rounded-lg">
                <h4 class="font-semibold text-gray-900">AI Development</h4>
                <p class="text-sm text-gray-600">Machine learning</p>
              </div>
              <div class="text-center p-4 bg-gray-50 rounded-lg">
                <h4 class="font-semibold text-gray-900">Web Development</h4>
                <p class="text-sm text-gray-600">Modern applications</p>
              </div>
              <div class="text-center p-4 bg-gray-50 rounded-lg">
                <h4 class="font-semibold text-gray-900">Mobile Apps</h4>
                <p class="text-sm text-gray-600">iOS & Android</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="bg-white rounded-lg shadow-lg p-8 border border-gray-100">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Send Us a Message</h3>
          <ContactForm />
        </div>
      </div>
      
      <!-- Additional Contact Methods -->
      <div class="mt-16 grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-lg shadow-lg p-6 border border-gray-100 text-center">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </div>
          <h4 class="text-xl font-semibold text-gray-900 mb-2">Live Chat Support</h4>
          <p class="text-gray-600 mb-4">Get instant answers to your questions</p>
          <button class="bg-gray-800 text-white px-6 py-2 rounded-lg hover:bg-gray-700 transition-colors">
            Start Chat
          </button>
        </div>
        
        <div class="bg-white rounded-lg shadow-lg p-6 border border-gray-100 text-center">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h4 class="text-xl font-semibold text-gray-900 mb-2">Schedule a Call</h4>
          <p class="text-gray-600 mb-4">Book a 30-minute consultation</p>
          <a href="https://calendly.com/fastship" target="_blank" rel="noopener" class="bg-gray-800 text-white px-6 py-2 rounded-lg hover:bg-gray-700 transition-colors inline-block">
            Book Now
          </a>
        </div>
        
        <div class="bg-white rounded-lg shadow-lg p-6 border border-gray-100 text-center">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h4 class="text-xl font-semibold text-gray-900 mb-2">Request Quote</h4>
          <p class="text-gray-600 mb-4">Get a detailed project estimate</p>
          <a href="/services" class="bg-gray-800 text-white px-6 py-2 rounded-lg hover:bg-gray-700 transition-colors inline-block">
            Learn More
          </a>
        </div>
      </div>
    </div>
  </Container>
</Layout>
