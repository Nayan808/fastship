---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

// SEO for 404 page
const seoTitle = "Page Not Found - 404 Error | FastShip IT Services";
const seoDescription = "The page you're looking for doesn't exist. Navigate back to FastShip's IT services, software development, or contact us for assistance.";
const seoKeywords = "404 error, page not found, FastShip, IT services, software development, custom software, AI development, digital transformation";

// Structured data for 404 page
const errorStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Page Not Found",
  "description": "The requested page could not be found",
  "url": "https://fastship.com/404"
};
---

<Layout 
  title="Page Not Found - 404 Error"
  description={seoDescription}
  keywords={seoKeywords}
  image="/logo.jpeg"
  structuredData={errorStructuredData}
  noindex={true}
>
  <Container>
    <div class="min-h-[70vh] flex items-center justify-center">
      <div class="text-center max-w-2xl mx-auto">
        <!-- 404 Icon -->
        <div class="mb-8">
          <div class="w-32 h-32 bg-gradient-to-r from-blue-600 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-6xl font-bold text-white">404</span>
          </div>
        </div>
        
        <!-- Error Message -->
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Page Not Found
        </h1>
        <p class="text-xl text-gray-600 mb-8 leading-relaxed">
          Oops! The page you're looking for doesn't exist. It might have been moved, deleted, or you entered the wrong URL.
        </p>
        
        <!-- Quick Navigation -->
        <div class="mb-8">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Navigation</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a href="/" class="bg-gray-100 hover:bg-gray-200 p-4 rounded-lg transition-colors">
              <div class="text-blue-600 font-semibold">Home</div>
              <div class="text-sm text-gray-600">Main page</div>
            </a>
            <a href="/services" class="bg-gray-100 hover:bg-gray-200 p-4 rounded-lg transition-colors">
              <div class="text-blue-600 font-semibold">Services</div>
              <div class="text-sm text-gray-600">What we offer</div>
            </a>
            <a href="/about" class="bg-gray-100 hover:bg-gray-200 p-4 rounded-lg transition-colors">
              <div class="text-blue-600 font-semibold">About</div>
              <div class="text-sm text-gray-600">Our company</div>
            </a>
            <a href="/contact" class="bg-gray-100 hover:bg-gray-200 p-4 rounded-lg transition-colors">
              <div class="text-blue-600 font-semibold">Contact</div>
              <div class="text-sm text-gray-600">Get in touch</div>
            </a>
          </div>
        </div>
        
        <!-- Popular Services -->
        <div class="mb-8">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Popular Services</h2>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/services#custom-software" class="bg-blue-100 text-blue-800 px-4 py-2 rounded-full hover:bg-blue-200 transition-colors">
              Custom Software
            </a>
            <a href="/services#ai-development" class="bg-green-100 text-green-800 px-4 py-2 rounded-full hover:bg-green-200 transition-colors">
              AI Development
            </a>
            <a href="/services#web-development" class="bg-purple-100 text-purple-800 px-4 py-2 rounded-full hover:bg-purple-200 transition-colors">
              Web Development
            </a>
            <a href="/services#mobile-development" class="bg-orange-100 text-orange-800 px-4 py-2 rounded-full hover:bg-orange-200 transition-colors">
              Mobile Apps
            </a>
          </div>
        </div>
        
        <!-- Call to Action -->
        <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg p-6 text-white">
          <h3 class="text-xl font-bold mb-3">Need Help?</h3>
          <p class="mb-4">
            Can't find what you're looking for? Our team is here to help you navigate our services.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
              Contact Support
            </a>
            <a href="/" class="bg-transparent text-white px-6 py-3 rounded-lg font-semibold border border-white hover:bg-white hover:text-blue-600 transition-colors">
              Go Home
            </a>
          </div>
        </div>
        
        <!-- Search Suggestion -->
        <div class="mt-8 p-4 bg-gray-50 rounded-lg">
          <p class="text-gray-600 mb-3">
            <strong>Tip:</strong> Use the search bar above or check our sitemap to find what you're looking for.
          </p>
          <a href="/sitemap.xml" class="text-blue-600 hover:text-blue-800 underline">
            View Sitemap
          </a>
        </div>
      </div>
    </div>
  </Container>
</Layout>
