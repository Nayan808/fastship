---
import { Icon } from "astro-icon/components";
---

<div class="mt-20 md:mt-32" id="fastship-10x">
  <div class="text-center mb-16">
    <h2 class="text-4xl lg:text-6xl font-bold lg:tracking-tight">
      FastShip 10x Faster
    </h2>
    <p class="text-lg mt-6 text-black max-w-4xl mx-auto">
      We don't just promise speed—we deliver it. Our unique combination of AI-powered development 
      and elite engineering teams means you get results that would take others months, in weeks.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
    <div class="feature-card service-card text-center p-6 bg-white rounded-xl border border-gray-200">
      <div class="bg-black text-white w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
        <Icon class="w-8 h-8" name="bx:rocket" />
      </div>
      <h3 class="text-xl font-semibold mb-3">Lightning Development</h3>
      <p class="text-black">
        AI agents work 24/7 alongside our engineers, turning ideas into working code faster than traditional methods.
      </p>
    </div>

    <div class="feature-card service-card text-center p-6 bg-white rounded-xl border border-gray-200">
      <div class="bg-black text-white w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
        <Icon class="w-8 h-8" name="bx:check" />
      </div>
      <h3 class="text-xl font-semibold mb-3">Outcome-First</h3>
      <p class="text-black">
        We measure success by what you ship, not by hours logged. Every sprint delivers tangible value.
      </p>
    </div>

    <div class="feature-card service-card text-center p-6 bg-white rounded-xl border border-gray-200">
      <div class="bg-black text-white w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
        <Icon class="w-8 h-8" name="bx:shield" />
      </div>
      <h3 class="text-xl font-semibold mb-3">Enterprise Security</h3>
      <p class="text-black">
        Bank-level security protocols built into every line of code. Your data and systems stay protected.
      </p>
    </div>
  </div>

  <div class="text-center mt-12">
    <p class="text-lg text-black mb-6">
      Ready to experience development at rocket speed?
    </p>
    <a 
      href="https://calendly.com/contact-fastship/30min?back=1&month=2025-08"
      target="_blank"
      rel="noopener"
      class="cta-button book-call-btn bg-black text-white px-8 py-4 rounded-lg hover:bg-gray-800 transition-colors inline-flex items-center gap-2 text-lg">
      <Icon class="w-6 h-6" name="bx:rocket" />
      Launch Your Project
    </a>
  </div>
</div>
