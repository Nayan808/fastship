---
import { Icon } from "astro-icon/components";
---

<div class="mt-20 md:mt-32" id="team-showcase">
  <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 bg-gray-100 px-4 py-2 rounded-full mb-6">
        <Icon class="w-4 h-4 text-black" name="bx:user" />
        <span class="text-sm font-medium text-black">Elite Team</span>
      </div>
    
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
      Meet the Rocket Engineers
    </h2>
    
    <p class="text-xl mt-6 text-black max-w-3xl mx-auto">
      Our team combines cutting-edge AI expertise with decades of engineering experience to deliver 
      solutions that launch businesses into the future.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
    <!-- Team Member 1 -->
    <div class="group">
      <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
        <div class="text-center mb-6">
          <!-- Stylized Avatar -->
          <div class="relative w-24 h-24 mx-auto mb-4">
            <div class="w-full h-full bg-black rounded-full flex items-center justify-center text-white text-2xl font-bold">
              JL
            </div>
            <!-- Floating Elements -->
            <div class="absolute -top-2 -right-2 w-6 h-6 bg-black rounded-full flex items-center justify-center">
              <Icon class="w-3 h-3 text-white" name="bx:check" />
            </div>
            <div class="absolute -bottom-2 -left-2 w-5 h-5 bg-black rounded-full flex items-center justify-center">
              <Icon class="w-2.5 h-2.5 text-white" name="bx:star" />
            </div>
          </div>
          
          <h3 class="text-xl font-bold text-gray-900 mb-2">Janette Lynch</h3>
          <p class="text-black font-medium mb-3">Chief Executive Officer</p>
          
          <!-- Skills Tags -->
          <div class="flex flex-wrap gap-2 justify-center mb-4">
            <span class="px-3 py-1 bg-gray-100 text-black text-xs rounded-full">AI Strategy</span>
            <span class="px-3 py-1 bg-gray-100 text-black text-xs rounded-full">Leadership</span>
            <span class="px-3 py-1 bg-gray-100 text-black text-xs rounded-full">Innovation</span>
          </div>
        </div>
        
        <p class="text-black text-center mb-6">
          Visionary leader driving FastShip's mission to transform businesses through innovative technology solutions.
        </p>
        
        <!-- Social Links -->
        <div class="flex justify-center gap-3">
          <a href="#" class="w-8 h-8 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
            <Icon class="w-4 h-4 text-black" name="bx:bxl-linkedin" />
          </a>
          <a href="#" class="w-8 h-8 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
            <Icon class="w-4 h-4 text-black" name="bx:bxl-twitter" />
          </a>
        </div>
      </div>
    </div>

    <!-- Team Member 2 -->
    <div class="group">
      <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
        <div class="text-center mb-6">
          <!-- Stylized Avatar -->
          <div class="relative w-24 h-24 mx-auto mb-4">
            <div class="w-full h-full bg-black rounded-full flex items-center justify-center text-white text-2xl font-bold">
              MZ
            </div>
            <!-- Floating Elements -->
            <div class="absolute -top-2 -right-2 w-6 h-6 bg-black rounded-full flex items-center justify-center">
              <Icon class="w-3 h-3 text-white" name="bx:code" />
            </div>
            <div class="absolute -bottom-2 -left-2 w-5 h-5 bg-black rounded-full flex items-center justify-center">
              <Icon class="w-2.5 h-2.5 text-white" name="bx:star" />
            </div>
          </div>
          
          <h3 class="text-xl font-bold text-gray-900 mb-2">Marcell Ziemann</h3>
          <p class="text-black font-medium mb-3">Chief Technology Officer</p>
          
          <!-- Skills Tags -->
          <div class="flex flex-wrap gap-2 justify-center mb-4">
            <span class="px-3 py-1 bg-gray-100 text-black text-xs rounded-full">Cloud Architecture</span>
            <span class="px-3 py-1 bg-gray-100 text-black text-xs rounded-full">AI/ML</span>
            <span class="px-3 py-1 bg-gray-100 text-black text-xs rounded-full">DevOps</span>
          </div>
        </div>
        
        <p class="text-black text-center mb-6">
          Technical architect ensuring FastShip delivers cutting-edge solutions that meet the highest standards.
        </p>
        
        <!-- Social Links -->
        <div class="flex justify-center gap-3">
          <a href="#" class="w-8 h-8 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
            <Icon class="w-4 h-4 text-black" name="bx:bxl-github" />
          </a>
          <a href="#" class="w-8 h-8 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
            <Icon class="w-4 h-4 text-black" name="bx:bxl-linkedin" />
          </a>
        </div>
      </div>
    </div>

    <!-- Team Member 3 -->
    <div class="group">
      <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
        <div class="text-center mb-6">
          <!-- Stylized Avatar -->
          <div class="relative w-24 h-24 mx-auto mb-4">
            <div class="w-full h-full bg-black rounded-full flex items-center justify-center text-white text-2xl font-bold">
              RP
            </div>
            <!-- Floating Elements -->
            <div class="absolute -top-2 -right-2 w-6 h-6 bg-black rounded-full flex items-center justify-center">
              <Icon class="w-3 h-3 text-white" name="bx:cog" />
            </div>
            <div class="absolute -bottom-2 -left-2 w-5 h-5 bg-black rounded-full flex items-center justify-center">
              <Icon class="w-2.5 h-2.5 text-white" name="bx:trending-up" />
            </div>
          </div>
          
          <h3 class="text-xl font-bold text-gray-900 mb-2">Robert Palmer</h3>
          <p class="text-black font-medium mb-3">VP of Engineering</p>
          
          <!-- Skills Tags -->
          <div class="flex flex-wrap gap-2 justify-center mb-4">
            <span class="px-3 py-1 bg-gray-100 text-black text-xs rounded-full">Team Leadership</span>
            <span class="px-3 py-1 bg-gray-100 text-black text-xs rounded-full">Agile</span>
            <span class="px-3 py-1 bg-gray-100 text-black text-xs rounded-full">Quality</span>
          </div>
        </div>
        
        <p class="text-black text-center mb-6">
          Engineering leader overseeing development processes and ensuring exceptional results for our clients.
        </p>
        
        <!-- Social Links -->
        <div class="flex justify-center gap-3">
          <a href="#" class="w-8 h-8 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
            <Icon class="w-4 h-4 text-black" name="bx:bxl-linkedin" />
          </a>
          <a href="#" class="w-8 h-8 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
            <Icon class="w-4 h-4 text-black" name="bx:bxl-twitter" />
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Join Team CTA -->
  <div class="text-center mt-16">
    <p class="text-lg text-black mb-6">
      Ready to join our elite team of rocket engineers?
    </p>
    <a 
      href="https://calendly.com/contact-fastship/30min?back=1&month=2025-08"
      target="_blank"
      rel="noopener"
      class="cta-button book-call-btn inline-flex items-center gap-3 bg-black text-white px-8 py-4 rounded-xl font-medium hover:bg-gray-800 transition-all duration-300 transform hover:scale-105 shadow-lg">
      <Icon class="w-6 h-6" name="bx:rocket" />
      Join the Team
    </a>
  </div>
</div>

