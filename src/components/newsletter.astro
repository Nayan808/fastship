---
import { Icon } from "astro-icon/components";
---

<div class="mt-20 md:mt-32 bg-white py-16 px-8 rounded-3xl border border-gray-200">
  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-white/80 backdrop-blur-sm px-4 py-2 rounded-full mb-6">
              <Icon class="w-4 h-4 text-black" name="bx:rocket" />
              <span class="text-sm font-medium text-black">AI Insights</span>
    </div>
    
    <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
      Stay Ahead of the AI Curve
    </h2>
    
            <p class="text-xl text-black mb-8 max-w-2xl mx-auto">
          Join our newsletter for exclusive insights and updates on the latest AI trends, 
          software development breakthroughs, and digital transformation strategies.
        </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center max-w-md mx-auto">
      <input 
        type="email" 
        placeholder="john@gmail.com" 
        class="flex-1 px-6 py-4 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-500 focus:border-transparent outline-none transition-all duration-300 bg-white"
      />
              <button class="bg-black text-white px-8 py-4 rounded-xl font-medium hover:bg-gray-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
          Subscribe
        </button>
    </div>
    
            <p class="text-sm text-black mt-4">
          🔒 We respect your privacy. Unsubscribe at any time.
        </p>
  </div>
</div>

