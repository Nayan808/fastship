---
import { Icon } from "astro-icon/components";
---

<div class="mt-20 md:mt-32" id="faq">
  <div class="text-center mb-16">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
      Frequently Asked Questions
    </h2>
    <p class="text-xl mt-6 text-black max-w-3xl mx-auto">
      Everything you need to know about working with FastShip
    </p>
  </div>

  <div class="max-w-4xl mx-auto space-y-4">
    <!-- FAQ Item 1 -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-white p-6 cursor-pointer hover:bg-gray-50 transition-colors">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium text-black">
            How do you define a "Sprint" at FastShip?
          </h3>
          <Icon class="text-gray-400 w-6 h-6" name="bx:plus" />
        </div>
      </div>
    </div>

    <!-- FAQ Item 2 -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-white p-6 cursor-pointer hover:bg-gray-50 transition-colors">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium text-black">
            What technology stack do you support?
          </h3>
          <Icon class="text-gray-400 w-6 h-6" name="bx:plus" />
        </div>
      </div>
    </div>

    <!-- FAQ Item 3 -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-white p-6 cursor-pointer hover:bg-gray-50 transition-colors">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium text-black">
            How does payment work with FastShip?
          </h3>
          <Icon class="text-gray-400 w-6 h-6" name="bx:plus" />
        </div>
      </div>
    </div>

    <!-- FAQ Item 4 -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-white p-6 cursor-pointer hover:bg-gray-50 transition-colors">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium text-black">
            How is FastShip different from traditional development agencies?
          </h3>
          <Icon class="text-gray-400 w-6 h-6" name="bx:plus" />
        </div>
      </div>
    </div>

    <!-- FAQ Item 5 -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <div class="bg-white p-6 cursor-pointer hover:bg-gray-50 transition-colors">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium text-black">
            Can FastShip integrate with existing enterprise systems securely?
          </h3>
          <Icon class="text-gray-400 w-6 h-6" name="bx:plus" />
        </div>
      </div>
    </div>
  </div>
</div>
