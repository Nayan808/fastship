---
import Container from "@/components/container.astro";
import Features from "@/components/features.astro";
import Hero from "@/components/hero.astro";
import Logos from "@/components/logos.astro";
import Layout from "@/layouts/Layout.astro";
import FastShip10x from "@/components/fastship-10x.astro";
import HowWeWork from "@/components/how-we-work.astro";
import ForRoles from "@/components/for-roles.astro";
import Reviews from "@/components/reviews.astro";
import Faq from "@/components/faq.astro";
import Stats from "@/components/stats.astro";

// Enhanced SEO-optimized content to outrank fastship.co and fastship.work
const seoTitle = "FastShip - Premier IT Services & Software Development Company | AI-Powered Development Solutions";
const seoDescription = "FastShip delivers cutting-edge IT services including custom software development, AI-powered solutions, digital transformation, and elite engineering teams. Get 10x faster results with our AI agents and innovative technology solutions. Leading software development company.";
const seoKeywords = "IT services, software development, AI agents, custom software, digital transformation, web development, mobile apps, cloud solutions, DevOps, artificial intelligence, machine learning, enterprise software, startup development, MVP development, rapid prototyping, agile development, software consulting, technology solutions, business automation, digital innovation, FastShip, fastship.co competitor, software company, AI development services, premier IT company, custom software solutions, enterprise software development, startup software development, AI-powered development, machine learning solutions, cloud computing services, DevOps consulting, digital transformation services, web application development, mobile application development, software architecture, microservices, API development, database design, UI/UX design, frontend development, backend development, full-stack development, React development, Node.js development, Python development, Java development, .NET development, AWS services, Azure services, Google Cloud services, Kubernetes, Docker, CI/CD, continuous integration, continuous deployment, agile methodology, scrum, kanban, project management, technical consulting, code review, testing services, quality assurance, performance optimization, security auditing, compliance, GDPR, HIPAA, SOC 2, ISO 27001";

// Structured data for the homepage
const homepageStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "FastShip - Premier IT Services & Software Development Company",
  "description": "FastShip delivers cutting-edge IT services including custom software development, AI-powered solutions, digital transformation, and elite engineering teams.",
  "url": "https://fastship.com",
  "mainEntity": {
    "@type": "Service",
    "name": "IT Services & Software Development",
    "description": "Comprehensive IT services including custom software development, AI solutions, and digital transformation",
    "provider": {
      "@type": "Organization",
      "name": "FastShip"
    },
    "areaServed": "Worldwide",
    "serviceType": [
      "Custom Software Development",
      "AI-Powered Development",
      "Digital Transformation",
      "Web Development",
      "Mobile App Development",
      "Cloud Solutions",
      "DevOps Services",
      "Software Consulting"
    ]
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://fastship.com"
      }
    ]
  }
};
---

<Layout 
  title=""
  description={seoDescription}
  keywords={seoKeywords}
  image="/logo.jpeg"
  structuredData={homepageStructuredData}
>
  <Container>
    <Hero />
    <FastShip10x />
    <Features />
    <Stats />
    <HowWeWork />
    <ForRoles />
    <Reviews />
    <Faq />
    <Logos />
  </Container>
</Layout>
