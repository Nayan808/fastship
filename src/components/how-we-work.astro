---
import { Icon } from "astro-icon/components";
---

<div class="mt-20 md:mt-32" id="how-we-work">
  <div class="grid lg:grid-cols-2 gap-16 items-center max-w-7xl mx-auto">
    <!-- Left Side - Content -->
    <div>
      <div class="inline-flex items-center px-3 py-1 rounded-full bg-gray-200 text-sm font-medium text-gray-700 mb-6">
        How We Work
      </div>
      <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight text-black mb-6">
        Fast and Secure <br/> Software Delivery.
      </h2>
      <p class="text-lg leading-relaxed text-black mb-8">
        We focus on shipping value, not counting minutes.
      </p>
    </div>

    <!-- Right Side - Feature Cards -->
    <div class="space-y-4">
      <!-- Discovery Call -->
      <div class="bg-gray-100 p-6 rounded-lg">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-lg font-bold text-gray-600">01</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-black mb-2">Discovery Call</h3>
            <p class="text-gray-600 leading-relaxed">
              We dive deep into your vision, understand your challenges, and align on what success looks like for your project.
            </p>
          </div>
        </div>
      </div>

      <!-- Weekly Sprints -->
      <div class="bg-gray-100 p-6 rounded-lg">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-lg font-bold text-gray-600">02</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-black mb-2">Weekly Sprints</h3>
            <p class="text-gray-600 leading-relaxed">
              Our elite engineers and AI-powered tools work in harmony to build and deploy features every single week.
            </p>
          </div>
        </div>
      </div>

      <!-- Check-ins -->
      <div class="bg-gray-100 p-6 rounded-lg">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-lg font-bold text-gray-600">03</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-black mb-2">Check-ins</h3>
            <p class="text-gray-600 leading-relaxed">
              Weekly progress reviews where we refine, reprioritize, and ensure we're always moving toward your goals.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
