---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Terms of Service - FastShip">
  <main class="min-h-screen bg-white">
    <!-- Hero Section -->
    <section class="py-20 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-5xl font-bold text-black mb-6">
            Terms of Service
          </h1>
          <p class="text-xl text-black mb-8">
            Please read these terms carefully before using our services.
          </p>
          <div class="flex items-center justify-center gap-4">
            <Icon class="w-8 h-8 text-black" name="bx:file" />
            <Icon class="w-8 h-8 text-black" name="bx:check-circle" />
            <Icon class="w-8 h-8 text-black" name="bx:shield" />
          </div>
        </div>
      </div>
    </section>

    <!-- Terms of Service Content -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto prose prose-lg">
          <div class="bg-gray-50 rounded-lg p-8 mb-8">
            <h2 class="text-2xl font-bold text-black mb-4">FastShip – Terms of Service</h2>
            <p class="text-black mb-4"><strong></strong> Founded in 2023</p>
          </div>

          <p class="text-black mb-8">
            Welcome to FastShip. These Terms of Service constitute a legally binding agreement between you and FastShip and govern your use of our website and services. By accessing or using FastShip, you agree to comply with these terms. If you do not agree, please refrain from using our platform.
          </p>

          <h3 class="text-2xl font-bold text-black mb-4">01 Definitions</h3>
          <ul class="list-disc pl-6 text-black mb-6">
            <li><strong>"FastShip"</strong> refers to our platform, website, and services.</li>
            <li><strong>"User"</strong> refers to any individual or entity using our services.</li>
            <li><strong>"Content"</strong> refers to any text, audio, video, or other media available on FastShip.</li>
          </ul>

          <h3 class="text-2xl font-bold text-black mb-4">02 Acceptance of Terms</h3>
          <p class="text-black mb-6">
            By accessing or using FastShip, you acknowledge that you have read, understood, and agree to be bound by these Terms and our Privacy Policy.
          </p>

          <h3 class="text-2xl font-bold text-black mb-4">03 User Obligations</h3>
          <ul class="list-disc pl-6 text-black mb-6">
            <li>You must provide accurate and up-to-date information during registration.</li>
            <li>You are responsible for maintaining the confidentiality of your account credentials.</li>
            <li>You must not misuse or attempt to exploit our services in any unlawful or unauthorized manner.</li>
            <li>You agree not to engage in any activity that disrupts or harms FastShip or its users.</li>
          </ul>

          <h3 class="text-2xl font-bold text-black mb-4">04 Privacy & Data Protection</h3>
          <p class="text-black mb-6">
            FastShip collects and processes user data as outlined in our Privacy Policy. By using our services, you consent to such processing.
          </p>

          <h3 class="text-2xl font-bold text-black mb-4">05 Intellectual Property Rights</h3>
          <ul class="list-disc pl-6 text-black mb-6">
            <li>FastShip and all related materials, including logos, designs, trademarks, and content, are owned by us or our licensors.</li>
            <li>You may not copy, reproduce, distribute, or create derivative works from any FastShip content without our express written consent.</li>
          </ul>

          <h3 class="text-2xl font-bold text-black mb-4">06 Third-Party Integrations</h3>
          <p class="text-black mb-6">
            FastShip may integrate with third-party services. We are not responsible for the accuracy, security, or reliability of third-party platforms and their data handling practices.
          </p>

          <h3 class="text-2xl font-bold text-black mb-4">07 Subscription & Payments</h3>
          <ul class="list-disc pl-6 text-black mb-6">
            <li>Certain features of FastShip may require a paid subscription.</li>
            <li>By purchasing a subscription, you agree to our pricing, billing, and refund policies.</li>
            <li>We reserve the right to change pricing at any time with prior notice to subscribers.</li>
          </ul>

          <h3 class="text-2xl font-bold text-black mb-4">08 Termination</h3>
          <p class="text-black mb-6">
            We may suspend or terminate your access to FastShip if you violate these Terms or engage in any activity that may harm our services or users.
          </p>

          <h3 class="text-2xl font-bold text-black mb-4">09 Limitation of Liability</h3>
          <ul class="list-disc pl-6 text-black mb-6">
            <li>FastShip is provided "as is" without any warranties, express or implied.</li>
            <li>We are not liable for any indirect, incidental, or consequential damages resulting from your use of FastShip.</li>
          </ul>

          <h3 class="text-2xl font-bold text-black mb-4">10 Governing Law & Dispute Resolution</h3>
          <p class="text-black mb-4">The terms of this Agreement shall be governed, interpreted, and construed in accordance with:</p>
          <ul class="list-disc pl-6 text-black mb-6">
            <li>The laws of the State of Delaware, United States if the Customer is located in the United States of America</li>
            <li>Laws of England & Wales if the Customer is located in Europe</li>
          </ul>
          <p class="text-black mb-6">
            All disputes, differences, claims, and demands arising under or pursuant to this Agreement shall be referred to arbitration and shall be adjudicated in accordance with the rules of the International Chamber of Commerce (I.C.C) in the English language in:
          </p>
          <ul class="list-disc pl-6 text-black mb-6">
            <li>The State of California if the Customer is located in the United States of America</li>
            <li>London, England if the Customer is located in Europe</li>
            <li>Hyderabad, Telangana India if the Customer is in India</li>
            <li>Singapore if the Customer is located in Asia (except India) or Australia</li>
          </ul>

          <h3 class="text-2xl font-bold text-black mb-4">11 Changes to Terms</h3>
          <p class="text-black mb-6">
            We reserve the right to update these Terms at any time. Changes will be effective upon posting on our website. Your continued use of FastShip constitutes acceptance of the revised Terms.
          </p>

          <div class="bg-gray-50 rounded-lg p-6 mt-8">
            <p class="text-black font-semibold">
              By using FastShip, you acknowledge that you have read, understood, and agreed to these Terms & Conditions.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-black mb-6">
            Questions About Our Terms?
          </h2>
          <p class="text-lg text-black mb-8">
            We're here to help clarify any questions about our terms of service.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="mailto:contact@fastship.work" 
               class="inline-flex items-center gap-2 bg-black text-white px-8 py-3 rounded-lg hover:bg-gray-800 transition-colors">
              <Icon class="w-5 h-5" name="bx:envelope" />
              Contact Us
            </a>
            <a href="/privacy-policy" 
               class="inline-flex items-center gap-2 border border-black text-black px-8 py-3 rounded-lg hover:bg-black hover:text-white transition-colors">
                             <Icon class="w-5 h-5" name="bx:shield" />
              Privacy Policy
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
