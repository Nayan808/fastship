---
import { Icon } from "astro-icon/components";
---

<div class="mt-20 md:mt-32" id="services">
  <div class="text-center mb-16">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight text-black">
      Our Services
    </h2>
    <p class="text-lg text-gray-600 mt-6 max-w-3xl mx-auto">
      We deliver cutting-edge solutions that accelerate your business growth and digital transformation
    </p>
  </div>

  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-8">
    <!-- AI Agents and Custom Chat Bots -->
    <div class="bg-white p-8 rounded-2xl border border-gray-200 hover:shadow-xl transition-all duration-300 group">
      <h3 class="text-2xl font-bold text-gray-800 mb-4">AI Agents & Custom Chat Bots</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        Intelligent AI agents that automate complex workflows and custom chatbots that enhance customer engagement. Built with cutting-edge NLP and machine learning.
      </p>
      <ul class="space-y-2">
        <li class="text-sm text-gray-600">Custom AI workflow automation</li>
        <li class="text-sm text-gray-600">Multi-language chatbot solutions</li>
        <li class="text-sm text-gray-600">Integration with existing systems</li>
      </ul>
    </div>

    <!-- Full Stack Development -->
    <div class="bg-white p-8 rounded-2xl border border-gray-200 hover:shadow-xl transition-all duration-300 group">
      <h3 class="text-2xl font-bold text-gray-800 mb-4">Full Stack Development</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        End-to-end web application development from database design to user interface. We build scalable, maintainable solutions using modern technologies.
      </p>
      <ul class="space-y-2">
        <li class="text-sm text-gray-600">Frontend & backend development</li>
        <li class="text-sm text-gray-600">Database design & optimization</li>
        <li class="text-sm text-gray-600">API development & integration</li>
      </ul>
    </div>

    <!-- Mobile App Development -->
    <div class="bg-white p-8 rounded-2xl border border-gray-200 hover:shadow-xl transition-all duration-300 group">
      <h3 class="text-2xl font-bold text-gray-800 mb-4">Mobile App Development</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        Native and cross-platform mobile applications that deliver exceptional user experiences. Built for performance, scalability, and user engagement.
      </p>
      <ul class="space-y-2">
        <li class="text-sm text-gray-600">iOS & Android development</li>
        <li class="text-sm text-gray-600">Cross-platform solutions</li>
        <li class="text-sm text-gray-600">App store optimization</li>
      </ul>
    </div>

    <!-- AI/ML Development -->
    <div class="bg-white p-8 rounded-2xl border border-gray-200 hover:shadow-xl transition-all duration-300 group">
      <h3 class="text-2xl font-bold text-gray-800 mb-4">AI/ML Development</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        Custom machine learning models and AI solutions that transform your data into actionable insights. From predictive analytics to computer vision.
      </p>
      <ul class="space-y-2">
        <li class="text-sm text-gray-600">Custom ML model development</li>
        <li class="text-sm text-gray-600">Predictive analytics solutions</li>
        <li class="text-sm text-gray-600">Computer vision & NLP</li>
      </ul>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="text-center mt-16">
    <p class="text-lg text-gray-600 mb-6">
      Ready to transform your business with our services?
    </p>
    <a 
      href="https://calendly.com/contact-fastship/30min?back=1&month=2025-08"
      target="_blank"
      rel="noopener"
      class="cta-button book-call-btn inline-flex items-center gap-3 bg-black text-white px-8 py-4 rounded-xl font-medium hover:bg-gray-800 transition-all duration-300 transform hover:scale-105 shadow-xl">
      <Icon class="w-6 h-6" name="bx:rocket" />
      Book a Call
    </a>
  </div>
</div>
