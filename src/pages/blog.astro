---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { getCollection } from "astro:content";
import SectionHead from "@/components/sectionhead.astro";

// Get all blog posts
const posts = await getCollection("blog");

// Enhanced SEO for blog page to outrank competitors
const seoTitle = "IT & Software Development Blog | FastShip - Expert Technology Insights";
const seoDescription = "Stay ahead with FastShip's expert insights on IT services, software development, AI technology, digital transformation, and industry best practices. Learn from our technology experts.";
const seoKeywords = "IT blog, software development blog, technology blog, AI blog, machine learning blog, digital transformation blog, web development blog, mobile development blog, cloud computing blog, DevOps blog, software architecture blog, programming blog, tech insights, industry best practices, FastShip blog, technology trends, software engineering blog, IT consulting blog, enterprise software blog, startup technology blog, coding blog, development tips, software design patterns, agile development blog, project management blog, technical leadership blog, FastShip, fastship.co competitor, premier IT company blog";

// Structured data for blog page
const blogStructuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "FastShip Technology Blog",
  "description": "Expert insights on IT services, software development, and technology trends",
  "url": "https://fastship.work/blog",
  "publisher": {
    "@type": "Organization",
    "name": "FastShip",
    "logo": {
      "@type": "ImageObject",
      "url": "https://fastship.work/logo.jpeg"
    }
  },
  "blogPost": posts.map((post, index) => ({
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.snippet || post.data.description,
    "author": {
      "@type": "Person",
      "name": post.data.author || "FastShip Team"
    },
    "datePublished": post.data.publishDate.toISOString(),
    "dateModified": post.data.publishDate.toISOString(),
    "url": `https://fastship.work/blog/${post.slug}`,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://fastship.work/blog/${post.slug}`
    }
  }))
};

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://fastship.work"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "https://fastship.work/blog"
    }
  ]
};
---

<Layout 
  title="IT & Software Development Blog"
  description={seoDescription}
  keywords={seoKeywords}
  image="/logo.jpeg"
  structuredData={[blogStructuredData, breadcrumbData]}
>
  <Container>
    <div class="mx-auto max-w-4xl mt-16">
      <SectionHead
        title="FastShip Technology Blog"
        description="Expert insights, industry trends, and best practices in IT services and software development. Stay ahead with our latest articles and technology updates."
      />
      
      <div class="grid gap-8 mt-16">
        {posts.map((post) => (
          <article class="bg-white rounded-lg shadow-lg p-8 border border-gray-100 hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-center gap-4 mb-4 text-sm text-gray-600">
              <time datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
              {post.data.author && (
                <span>by {post.data.author}</span>
              )}
            </div>
            
            <h2 class="text-2xl font-bold text-gray-900 mb-4 hover:text-gray-700 transition-colors">
              <a href={`/blog/${post.slug}`}>
                {post.data.title}
              </a>
            </h2>
            
            <p class="text-gray-600 mb-6 leading-relaxed">
              {post.data.snippet || post.data.description}
            </p>
            
            <div class="flex flex-wrap gap-2 mb-6">
              {post.data.tags && post.data.tags.map((tag) => (
                <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded">
                  {tag}
                </span>
              ))}
            </div>
            
            <a 
              href={`/blog/${post.slug}`}
              class="inline-flex items-center text-gray-800 hover:text-black font-medium transition-colors"
            >
              Read More
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </article>
        ))}
      </div>
      
      <!-- Blog Categories and Topics -->
      <div class="mt-16 bg-gray-50 rounded-lg p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Popular Topics & Categories</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="/blog?tag=ai" class="bg-white p-4 rounded-lg text-center hover:shadow-md transition-shadow">
            <h4 class="font-semibold text-gray-900">AI & Machine Learning</h4>
            <p class="text-sm text-gray-600">Latest developments</p>
          </a>
          <a href="/blog?tag=web-development" class="bg-white p-4 rounded-lg text-center hover:shadow-md transition-shadow">
            <h4 class="font-semibold text-gray-900">Web Development</h4>
            <p class="text-sm text-gray-600">Modern frameworks</p>
          </a>
          <a href="/blog?tag=cloud" class="bg-white p-4 rounded-lg text-center hover:shadow-md transition-shadow">
            <h4 class="font-semibold text-gray-900">Cloud Computing</h4>
            <p class="text-sm text-gray-600">AWS, Azure, GCP</p>
          </a>
          <a href="/blog?tag=devops" class="bg-white p-4 rounded-lg text-center hover:shadow-md transition-shadow">
            <h4 class="font-semibold text-gray-900">DevOps</h4>
            <p class="text-sm text-gray-600">CI/CD & automation</p>
          </a>
        </div>
      </div>
      

    </div>
  </Container>
</Layout>
