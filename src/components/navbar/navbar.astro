---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  {
    title: "About",
    path: "/about",
  },
  {
    title: "Work",
    path: "/work",
  },
  {
    title: "Blogs",
    path: "/blog",
  },
  {
    title: "Services",
    path: "/services",
  },
  {
    title: "Careers",
    path: "/careers",
  },
];
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="flex items-center">
          <img src="/logoNavbar.png" alt="FastShip Logo" class="h-15 w-auto" />
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="text-gray-800 w-4 h-4" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-8">
          {
            menuitems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class="flex lg:px-3 py-2 items-center text-gray-600 hover:text-gray-900 font-medium transition-colors">
                  <span>{item.title}</span>
                </a>
              </li>
            ))
          }
        </ul>
        <div class="lg:hidden flex items-center mt-3 gap-4">
          <a href="https://calendly.com/contact-fastship/30min?back=1&month=2025-08" target="_blank" rel="noopener" class="cta-button book-call-btn bg-black text-white px-6 py-2 rounded-lg hover:bg-gray-800 transition-colors">
            Book a Call
          </a>
        </div>
      </MenuItems>
    </Astronav>
    <div>
      <div class="hidden lg:flex items-center">
        <a href="https://calendly.com/contact-fastship/30min?back=1&month=2025-08" target="_blank" rel="noopener" class="cta-button book-call-btn bg-black text-white px-6 py-2 rounded-lg hover:bg-gray-800 transition-colors">
          Book a Call
        </a>
      </div>
    </div>
  </header>
</Container>
