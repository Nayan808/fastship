---
import { Icon } from "astro-icon/components";
---

<footer class="mt-20 border-t border-gray-200">
  <!-- Newsletter Section -->
  <div class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h3 class="text-3xl font-bold text-gray-900 mb-4">
            Ready to Launch?
          </h3>
          <p class="text-lg text-black mb-6">
            Let's discuss how FastShip can transform your business with innovative technology solutions.
          </p>
          <a 
            href="https://calendly.com/contact-fastship/30min?back=1&month=2025-08"
            target="_blank"
            rel="noopener"
            class="cta-button book-call-btn inline-flex items-center gap-2 bg-black text-white px-8 py-4 rounded-xl font-medium hover:bg-gray-800 transition-all duration-300 transform hover:scale-105">
            <Icon class="w-5 h-5" name="bx:rocket" />
            Book a Call
          </a>
        </div>
        

      </div>
    </div>
  </div>
  
  <!-- Main Footer -->
  <div class="py-12 bg-white">
    <div class="max-w-6xl mx-auto px-8">
      <div class="grid md:grid-cols-4 gap-8">
        <!-- Company Info -->
        <div class="md:col-span-2">
          <div class="flex items-center gap-2 mb-4">
            <Icon class="w-6 h-6 text-black" name="bx:home" />
            <span class="text-lg font-bold text-gray-900">FastShip</span>
          </div>
          <p class="text-black mb-6 max-w-md">
            We don't just ship code, We launch Rocket. Transform your business with AI-powered development and elite engineering teams.
          </p>
          <div class="flex items-center gap-4">
                    <a href="#" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
          <Icon class="w-5 h-5 text-black" name="bx:bxl-github" />
        </a>
                          <a href="#" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
                <Icon class="w-5 h-5 text-black" name="bx:bxl-twitter" />
              </a>
                          <a href="#" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
                <Icon class="w-5 h-5 text-black" name="bx:bxl-discord" />
              </a>
                          <a href="#" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors">
                <Icon class="w-5 h-5 text-black" name="bx:bxl-linkedin" />
              </a>
          </div>
        </div>
        
        <!-- Quick Links -->
        <div>
          <h4 class="font-semibold text-gray-900 mb-4">Quick Links</h4>
          <ul class="space-y-2">
            <li><a href="/about" class="text-gray-600 hover:text-black transition-colors">About</a></li>
            <li><a href="/#services" class="text-gray-600 hover:text-black transition-colors">Services</a></li>


          </ul>
        </div>
        
        <!-- Resources -->
        <div>
          <h4 class="font-semibold text-gray-900 mb-4">Resources</h4>
          <ul class="space-y-2">
            <li><a href="#" class="text-gray-600 hover:text-black transition-colors">Documentation</a></li>
            <li><a href="#" class="text-gray-600 hover:text-black transition-colors">Help Center</a></li>
            <li><a href="#" class="text-gray-600 hover:text-black transition-colors">Privacy Policy</a></li>
            <li><a href="#" class="text-gray-600 hover:text-black transition-colors">Terms of Service</a></li>
          </ul>
        </div>
      </div>
      
      <!-- Bottom Bar -->
      <div class="border-t border-gray-200 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center">
        <p class="text-black text-sm">
          © 2025 FastShip. All rights reserved.
        </p>
        <p class="text-black text-sm mt-2 md:mt-0">
          We don't just ship code, We launch Rocket 🚀
        </p>
      </div>
    </div>
  </div>
</footer>
