---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import SectionHead from "@/components/sectionhead.astro";

// Enhanced SEO for careers page to outrank competitors
const seoTitle = "Careers at FastShip - Join Our Elite Engineering Team | IT Services & Software Development Jobs";
const seoDescription = "Join FastShip's elite engineering team and work on cutting-edge technology projects. We're hiring software developers, AI engineers, DevOps specialists, and more. Competitive salaries, remote work, and growth opportunities.";
const seoKeywords = "careers at FastShip, FastShip jobs, software development jobs, IT services careers, AI engineer jobs, DevOps jobs, web developer jobs, mobile developer jobs, software engineer jobs, technology careers, remote work jobs, engineering jobs, software development careers, IT consulting jobs, technology company jobs, startup jobs, enterprise software jobs, FastShip, fastship competitor, premier IT company careers";

// Structured data for careers page
const careersStructuredData = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": "Software Development and IT Services Careers",
  "description": "Join FastShip's elite engineering team and work on cutting-edge technology projects",
  "hiringOrganization": {
    "@type": "Organization",
    "name": "FastShip",
    "url": "https://fastship.work",
    "logo": "https://fastship.work/logo.jpeg"
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "US"
    }
  },
  "employmentType": ["FULL_TIME", "CONTRACT", "REMOTE"],
  "datePosted": "2024-12-19",
  "validThrough": "2025-12-19"
};

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://fastship.work"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Careers",
      "item": "https://fastship.work/careers"
    }
  ]
};
---

<Layout 
  title="Careers at FastShip - Join Our Elite Team"
  description={seoDescription}
  keywords={seoKeywords}
  image="/logo.jpeg"
  structuredData={[careersStructuredData, breadcrumbData]}
>
  <Container>
    <div class="mx-auto max-w-4xl mt-16">
      <SectionHead
        title="Careers at FastShip - Join Our Elite Engineering Team"
        description="Work on cutting-edge technology projects and help businesses achieve 10x faster results with AI-powered solutions. Join our team of technology innovators and problem solvers."
      />
      
      <!-- LinkedIn Only Hiring Notice -->
      <div class="mt-16 bg-gray-100 rounded-lg p-12 text-center">
        <div class="w-24 h-24 bg-black rounded-full flex items-center justify-center mx-auto mb-8">
          <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <h2 class="text-4xl font-bold text-black mb-6">We Only Hire Through LinkedIn</h2>
        <p class="text-xl text-gray-700 mb-8 leading-relaxed">
          All our job postings and recruitment activities happen exclusively on LinkedIn. 
          Follow our company page to stay updated with current openings and opportunities.
        </p>
        
        <div class="bg-white rounded-lg p-8 border border-gray-200 max-w-2xl mx-auto">
          <h3 class="text-2xl font-bold text-black mb-6">How to Apply for Jobs at FastShip</h3>
          <div class="space-y-4 text-left">
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-black rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-white font-bold text-sm">1</span>
              </div>
              <div>
                <h4 class="font-semibold text-black">Follow Our Company Page</h4>
                <p class="text-gray-600">Get notified of new positions and company updates</p>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-black rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-white font-bold text-sm">2</span>
              </div>
              <div>
                <h4 class="font-semibold text-black">Monitor Job Postings</h4>
                <p class="text-gray-600">All openings are posted exclusively on LinkedIn</p>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-black rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-white font-bold text-sm">3</span>
              </div>
              <div>
                <h4 class="font-semibold text-black">Apply Through LinkedIn</h4>
                <p class="text-gray-600">Submit your application directly via LinkedIn</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="mt-8">
          <a 
            href="https://linkedin.com/company/fastship-work" 
            target="_blank" 
            rel="noopener"
            class="bg-black text-white px-8 py-4 rounded-lg font-semibold hover:bg-gray-800 transition-colors inline-flex items-center gap-3"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Visit Our LinkedIn Company Page
          </a>
        </div>
      </div>
      
      <!-- Company Information -->
      <div class="mt-16 bg-white rounded-lg shadow-lg p-8 border border-gray-200">
        <h3 class="text-2xl font-bold text-black mb-6">About FastShip - Our Company</h3>
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h4 class="text-lg font-semibold text-black mb-3">Our Mission</h4>
            <p class="text-gray-700 leading-relaxed">
              To empower businesses with cutting-edge technology solutions that drive innovation, 
              efficiency, and growth. We deliver 10x faster results through AI-powered development 
              and elite engineering expertise.
            </p>
          </div>
          
          <div>
            <h4 class="text-lg font-semibold text-black mb-3">What We Do</h4>
            <p class="text-gray-700 leading-relaxed">
              We specialize in custom software development, AI solutions, digital transformation, 
              and providing elite engineering teams to help businesses stay ahead of the competition.
            </p>
          </div>
        </div>
      </div>
      
      <!-- Call to Action -->
      <div class="mt-16 bg-black rounded-lg p-8 text-white text-center">
        <h3 class="text-2xl font-bold mb-4">Ready to Join FastShip?</h3>
        <p class="text-lg mb-6">
          Follow our LinkedIn company page to stay updated with current opportunities and company news.
        </p>
        <a 
          href="https://linkedin.com/company/fastship-work" 
          target="_blank" 
          rel="noopener"
          class="bg-white text-black px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
        >
          Follow on LinkedIn
        </a>
      </div>
    </div>
  </Container>
</Layout>
